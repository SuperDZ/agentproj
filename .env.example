# 数据库：Prisma 运行时读取 DATABASE_URL 连接 PostgreSQL。
DATABASE_URL=""

# 数据库拆分参数：便于本地脚本或部署平台组装 DATABASE_URL。
DB_HOST=""
DB_PORT=""
DB_USER=""
DB_PASSWORD=""
DB_NAME=""

# Redis：只作为缓存、短期幂等键、限流计数和 worker 唤醒信号；不作为事实源。
REDIS_URL="redis://127.0.0.1:6379"
CACHE_ENABLED="true"
CACHE_DEFAULT_TTL_SECONDS="300"

# AsyncTask worker 领取任务后的租约时长，单位毫秒；租约过期后其他 worker 可恢复。
ASYNC_TASK_LOCK_TTL_MS="120000"

# Artifact Storage：小文本可内联到数据库，大文件落本地文件系统。
ARTIFACT_STORAGE_DIR=".data/artifacts"
ARTIFACT_INLINE_MAX_BYTES="262144"

# Hermes 运行模式：默认 local，表示接入真实 Hermes HTTP API；可选 real、local、mock。
HERMES_MODE="local"

# Hermes 真实接口地址：real 模式必填，例如 https://your-hermes-api.example。
HERMES_API_BASE_URL=""

# Hermes 真实接口鉴权密钥：如果 Hermes 服务要求 Bearer token，则必填。
HERMES_API_KEY=""

# Hermes 结果读取路径模板：当最终 output 不在 /runs/{runId} 或 /runs/{runId}/events 时配置。
HERMES_RESEARCH_OUTPUT_PATH_TEMPLATE=""

# 研究 worker 空闲轮询间隔，单位毫秒；值越小响应越快，数据库查询越频繁。
HERMES_RESEARCH_WORKER_POLL_MS="5000"

# running 任务恢复阈值，单位毫秒；用于 worker 崩溃后恢复未拿到 hermesRunId 的任务。
HERMES_RESEARCH_STALE_RUNNING_MS="900000"

# 本机 Hermes 源码目录：local 模式使用。
HERMES_LOCAL_ROOT=""

# 本机 Hermes Python 解释器路径：local 模式通过它执行 hermes_cli.main。
HERMES_LOCAL_PYTHON=""

# 本机 Hermes CLI 超时时间，单位毫秒。
HERMES_LOCAL_TIMEOUT_MS=""

# local 模式模型供应商覆盖项；优先级高于 HERMES_INFERENCE_PROVIDER。
HERMES_LOCAL_PROVIDER=""

# local 模式模型名覆盖项；优先级高于 HERMES_INFERENCE_MODEL。
HERMES_LOCAL_MODEL=""

# 默认模型供应商：未保存面板配置、未设置 local 覆盖项时使用。
HERMES_INFERENCE_PROVIDER=""

# 默认模型名：未保存面板配置、未设置 local 覆盖项时使用。
HERMES_INFERENCE_MODEL=""

# DeepSeek API key：provider 为 deepseek 时使用。
DEEPSEEK_API_KEY=""

# DeepSeek 兼容接口地址：为空时使用代码内置默认地址。
DEEPSEEK_BASE_URL=""

# DashScope API key：provider 为 qwen 时使用。
DASHSCOPE_API_KEY=""

# DashScope OpenAI-compatible 接口地址：为空时使用代码内置默认地址。
DASHSCOPE_BASE_URL=""

# OpenAI API key：provider 为 openai 时使用。
OPENAI_API_KEY=""

# OpenAI 兼容接口地址：为空时使用代码内置默认地址。
OPENAI_BASE_URL=""

# GitHub API token：用于仓库搜索、读取默认分支和文件树，降低限流风险。
GITHUB_TOKEN=""

# GitHub CLI/API token 备用名：未设置 GITHUB_TOKEN 时使用。
GH_TOKEN=""
