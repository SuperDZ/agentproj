generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id           String              @id @default(cuid())
  name         String
  idea         String
  industry     String
  targetUser   String
  needFinancialSuitabilityCheck Boolean @default(false)
  needContinuousCompetitorMonitoring Boolean @default(false)
  preferredTechStack String?
  status       String              @default("draft")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  researchRuns ResearchRun[]
  competitors  Competitor[]
  evaluations  Evaluation[]
  artifacts    GeneratedArtifact[]
  storedArtifacts StoredArtifact[]
  monitorJobs  MonitorJob[]
  reports      MonitorReport[]
  asyncTasks   AsyncTask[]
  agentReviews AgentReview[]
  operationalEvents OperationalEvent[]
  modelInvocations ModelInvocation[]
}

model ResearchRun {
  id               String    @id @default(cuid())
  projectId        String
  hermesRunId      String?
  mode             String
  status           String    @default("queued")
  inputPrompt      String
  rawOutput        String?
  parsedOutputJson String?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Competitor {
  id                String   @id @default(cuid())
  projectId         String
  name              String
  type              String
  url               String
  description       String
  coreFeaturesJson  String
  strengthsJson     String
  weaknessesJson    String
  reusableIdeasJson String
  threatLevel       Int
  reuseStrategy     String
  createdAt         DateTime @default(now())

  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Evaluation {
  id                   String   @id @default(cuid())
  projectId            String
  pdrs                 Float
  opportunityScore     Int
  competitiveScore     Int
  specificationScore   Int
  prototypeScore       Int
  promptReadinessScore Int
  redundancyRisk       Int
  differentiationScore Int
  decision             String
  risksJson            String
  nextActionsJson      String
  scoreReasonsJson     String              @default("{}")
  createdAt            DateTime @default(now())

  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model GeneratedArtifact {
  id           String   @id @default(cuid())
  projectId    String
  artifactType String
  content      String
  version      Int      @default(1)
  createdAt    DateTime @default(now())

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  storedArtifacts StoredArtifact[]

  @@index([projectId, artifactType])
}

model AsyncTask {
  id            String             @id @default(cuid())
  type          String
  projectId     String?
  status        String             @default("queued")
  payloadJson   String             @default("{}")
  resultJson    String?
  priority      Int                @default(0)
  attemptCount  Int                @default(0)
  maxAttempts   Int                @default(3)
  runAfter      DateTime           @default(now())
  lockedBy      String?
  lockExpiresAt DateTime?
  lastError     String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  completedAt   DateTime?

  project       Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  attempts      AsyncTaskAttempt[]
  events        OperationalEvent[]
  spans         TraceSpan[]
  agentRuns     AgentRun[]
  agentConsensuses AgentConsensus[]

  @@index([status, runAfter, priority, createdAt])
  @@index([projectId, type, status])
  @@index([lockedBy, lockExpiresAt])
}

model AgentReview {
  id                  String           @id @default(cuid())
  projectId           String
  targetType          String
  targetArtifactId    String?
  targetChecksum      String?
  status              String           @default("queued")
  decision            String?
  round               Int              @default(1)
  expectedRunCount    Int              @default(0)
  completedRunCount   Int              @default(0)
  synthesizeTaskId    String?          @unique
  synthesizeStartedAt DateTime?
  snapshotArtifactId  String?
  latestConsensusId   String?
  createdBy           String?
  startedAt           DateTime?
  endedAt             DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  project             Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs                AgentRun[]
  findings            AgentFinding[]
  consensuses         AgentConsensus[]

  @@unique([projectId, targetType, round])
  @@index([projectId, targetType, createdAt])
  @@index([status, createdAt])
  @@index([decision, createdAt])
}

model AgentRun {
  id                 String          @id @default(cuid())
  projectId          String
  reviewId           String
  taskId             String?
  agentKey           String
  role               String
  status             String          @default("queued")
  inputArtifactId    String?
  outputJson         Json?
  outputArtifactId   String?
  traceId            String?
  promptVersion      String
  model              String?
  retryCount         Int             @default(0)
  maxRetries         Int             @default(5)
  lastErrorCode      String?
  lastErrorMessage   String?
  isRetriedRun       Boolean         @default(false)
  supersededByRunId  String?
  startedAt          DateTime?
  endedAt            DateTime?
  durationMs         Int?
  errorCode          String?
  errorMessage       String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  review             AgentReview     @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  task               AsyncTask?      @relation(fields: [taskId], references: [id], onDelete: SetNull)
  findings           AgentFinding[]

  @@index([projectId, createdAt])
  @@index([reviewId, agentKey, createdAt])
  @@index([taskId])
  @@index([status, createdAt])
}

model AgentFinding {
  id                  String                    @id @default(cuid())
  projectId           String
  reviewId            String
  agentRunId          String?
  severity            String
  category            String
  title               String
  description         String
  evidenceJson        Json?
  recommendation      String?
  confidence          Float?
  status              String                    @default("open")
  dedupeKey           String
  isConsensusFinding  Boolean                   @default(false)
  mergedIntoFindingId String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  review              AgentReview               @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  agentRun            AgentRun?                 @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  consensusLinks      AgentConsensusFinding[]

  @@index([projectId, createdAt])
  @@index([reviewId, severity, status])
  @@index([reviewId, dedupeKey])
  @@index([agentRunId])
}

model AgentConsensus {
  id               String                   @id @default(cuid())
  projectId        String
  reviewId         String
  taskId           String?
  decision         String
  summary          String
  outputArtifactId String?
  ruleResultJson   Json?
  createdAt        DateTime                 @default(now())

  review           AgentReview              @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  task             AsyncTask?               @relation(fields: [taskId], references: [id], onDelete: SetNull)
  findings         AgentConsensusFinding[]

  @@index([projectId, createdAt])
  @@index([reviewId, createdAt])
  @@index([taskId])
  @@index([decision, createdAt])
}

model AgentConsensusFinding {
  id          String         @id @default(cuid())
  consensusId String
  findingId   String
  rank        Int?
  createdAt   DateTime       @default(now())

  consensus   AgentConsensus @relation(fields: [consensusId], references: [id], onDelete: Cascade)
  finding     AgentFinding   @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@unique([consensusId, findingId])
  @@index([findingId])
}

model AsyncTaskAttempt {
  id           String    @id @default(cuid())
  taskId       String
  workerId     String
  status       String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  durationMs   Int?
  error        String?
  metadataJson String    @default("{}")

  task         AsyncTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, startedAt])
  @@index([workerId, startedAt])
}

model WorkerHeartbeat {
  id           String   @id @default(cuid())
  workerId     String   @unique
  hostname     String
  pid          Int
  status       String   @default("running")
  lastSeenAt   DateTime @default(now())
  metadataJson String   @default("{}")

  @@index([status, lastSeenAt])
}

model OperationalEvent {
  id           String    @id @default(cuid())
  level        String
  source       String
  eventType    String
  message      String
  traceId      String?
  projectId    String?
  taskId       String?
  metadataJson String    @default("{}")
  createdAt    DateTime  @default(now())

  project      Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task         AsyncTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([level, createdAt])
  @@index([projectId, createdAt])
  @@index([taskId, createdAt])
  @@index([traceId])
}

model MetricSample {
  id        String   @id @default(cuid())
  name      String
  value     Float
  unit      String?
  tagsJson  String   @default("{}")
  createdAt DateTime @default(now())

  @@index([name, createdAt])
}

model TraceSpan {
  id             String    @id @default(cuid())
  traceId        String
  spanId         String    @unique
  parentSpanId   String?
  name           String
  status         String    @default("running")
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  durationMs     Int?
  projectId      String?
  taskId         String?
  attributesJson String    @default("{}")

  task           AsyncTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([traceId, startedAt])
  @@index([projectId, startedAt])
  @@index([taskId, startedAt])
  @@index([status, startedAt])
}

model ModelInvocation {
  id               String    @id @default(cuid())
  provider         String
  model            String
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  estimatedCostUsd Float?
  latencyMs        Int
  status           String
  projectId        String?
  traceId          String?
  error            String?
  createdAt        DateTime  @default(now())

  project          Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([provider, model, createdAt])
  @@index([projectId, createdAt])
  @@index([traceId])
  @@index([status, createdAt])
}

model StoredArtifact {
  id                  String             @id @default(cuid())
  projectId           String
  generatedArtifactId String?
  artifactType        String
  filename            String
  mimeType            String
  storageKind         String
  storageKey          String
  sizeBytes           Int
  checksumSha256      String
  textPreview         String?
  version             Int                @default(1)
  createdAt           DateTime           @default(now())

  project             Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  generatedArtifact   GeneratedArtifact? @relation(fields: [generatedArtifactId], references: [id], onDelete: SetNull)

  @@index([projectId, artifactType, createdAt])
  @@index([generatedArtifactId])
  @@unique([projectId, storageKey])
}

model MonitorJob {
  id              String          @id @default(cuid())
  projectId       String
  hermesCronJobId String?
  schedule        String
  status          String          @default("active")
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  createdAt       DateTime        @default(now())

  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reports         MonitorReport[]

  @@index([projectId])
}

model MonitorReport {
  id                        String     @id @default(cuid())
  projectId                 String
  jobId                     String
  differentiationDriftScore Int
  summary                   String
  alertsJson                String
  recommendedActionsJson    String
  createdAt                 DateTime   @default(now())

  project                   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  job                       MonitorJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([projectId, jobId])
}
